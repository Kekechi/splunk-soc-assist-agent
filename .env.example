# Copy to `.env` and fill in. Nothing here is hardcoded in the source.
# `.env` is gitignored — never commit real tokens.

# ── Anthropic (Claude Agent SDK) ──────────────────────────────────────────────
# Pick ONE auth path — the SDK reads whichever you set.
#
# A) Claude subscription (Pro/Max). No API key needed. Install the Claude Code
#    CLI and either `claude` (interactive login) or mint a headless token with
#    `claude setup-token`, then set it here. Leave ANTHROPIC_API_KEY blank.
#    Note: from 2026-06-15, SDK usage on a subscription draws from a separate
#    monthly "Agent SDK credit."
CLAUDE_CODE_OAUTH_TOKEN=
#
# B) API billing (metered, pay-as-you-go — NOT covered by a subscription).
#    Generate a key at platform.claude.com -> API Keys. Leave CLAUDE_CODE_OAUTH_TOKEN blank.
ANTHROPIC_API_KEY=

# ── Splunk MCP server (READ plane) ────────────────────────────────────────────
# HTTP(S) endpoint of the "MCP Server for Splunk platform" app.
SPLUNK_MCP_URL=https://your-splunk-host:8089/services/mcp
# Transport the server speaks: "http" (streamable-HTTP) or "sse".
SPLUNK_MCP_TRANSPORT=http
# Auth header scheme + token. Splunk commonly uses "Bearer <token>"; some
# deployments use "Splunk <token>". The service role needs `mcp_tool_execute`,
# and "Splunk AI Assistant for SPL" must be installed for the saia_* tools.
SPLUNK_MCP_AUTH_SCHEME=Bearer
SPLUNK_MCP_TOKEN=

# ── Splunk REST write target (WRITE plane — Phase 3) ──────────────────────────
# The SINGLE app context that will own generated Dashboard Studio views.
# The write @tool can physically POST to this app's data/ui/views and nowhere else.
SPLUNK_REST_URL=https://your-splunk-host:8089
SPLUNK_WRITE_APP=search
SPLUNK_WRITE_TOKEN=

# ── Slack (NOTIFY plane — Phase 4) ────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_CHANNEL=

# ── Audit (AUDIT plane — Phase 6) ─────────────────────────────────────────────
SPLUNK_AUDIT_INDEX=soc_assist_audit
