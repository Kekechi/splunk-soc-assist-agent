# Secrets / local config
.env
*.env
!.env.example

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Deployment profiles name deployment-specific indexes/sourcetypes — gitignored.
# The public, env-agnostic template profiles/example.toml is the one exception.
/profiles/*.toml
!/profiles/example.toml

# Local dev/session notes — not part of the public repo (may contain
# deployment-specific hostnames). The SDK does not treat this as config.
.claude/session/

# Local-only workarounds & notes — never part of the public repo.
.local/
CLAUDE.local.md
.claude/settings.local.json
